# Base URL for the client build (for GitHub Pages deployment)
# For local development: leave empty or set to '/'
# For GitHub Pages: set to '/your-repo-name/' (e.g., '/newavalon.xyz/')
BASE_URL=

# Server port (default: 8822)
PORT=8822

# VU Test Panel - Enable VU system debug panel in development
# Set to 'true' to show the VU test panel during development
VITE_SHOW_VU_PANEL=false
